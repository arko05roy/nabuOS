{
  "name": "@nabuos/guard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "OTEL_SERVICE_NAME=guard tsx watch --import @nabuos/otel/instrument src/index.ts",
    "start": "OTEL_SERVICE_NAME=guard node --import @nabuos/otel/instrument --env-file=../../.env dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@nabuos/deps-dev": "workspace:*",
    "@nabuos/guard-triage": "workspace:*",
    "@nabuos/npm-artifact": "workspace:*",
    "@nabuos/npm-registry": "workspace:*",
    "@nabuos/osv": "workspace:*",
    "@nabuos/pypi-registry": "workspace:*",
    "@nabuos/pypi-artifact": "workspace:*",
    "@nabuos/semgrep": "workspace:*",
    "@nabuos/sandbox": "workspace:*",
    "@nabuos/otel": "workspace:*",
    "@nabuos/service-kit": "workspace:*",
    "@nabuos/types": "workspace:*",
    "hono": "^4.7.11"
  },
  "devDependencies": {
    "tsx": "^4.19.4"
  }
}
