{
  "name": "@nabuos/sandbox-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "OTEL_SERVICE_NAME=sandbox-worker tsx watch --import @nabuos/otel/instrument src/index.ts",
    "start": "OTEL_SERVICE_NAME=sandbox-worker node --import @nabuos/otel/instrument dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@nabuos/otel": "workspace:*",
    "@nabuos/sandbox": "workspace:*",
    "@nabuos/service-kit": "workspace:*",
    "@nabuos/types": "workspace:*",
    "hono": "^4.7.11"
  },
  "devDependencies": {
    "tsx": "^4.19.4"
  }
}
