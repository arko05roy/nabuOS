# Environment variables (copy to .env — never commit .env)

# Service ports (defaults shown)
# PORT=3100  # api-gateway
# PORT=3001  # guard
# PORT=3002  # mind
# PORT=3003  # vault
# PORT=3004  # run
# PORT=3005  # sandbox-worker
# PORT=3006  # pulse

# BTL Runtime — only required external service for v0
GATEWAY_API_KEY=
BTL_RUNTIME_BASE_URL=https://api.badtheorylabs.com/v1
BTL_SMOKE_MODEL=btl-2

# Service URLs for cross-service smoke tests (defaults shown)
# GUARD_URL=http://127.0.0.1:3001
# MIND_URL=http://127.0.0.1:3002
# VAULT_URL=http://127.0.0.1:3003
# RUN_URL=http://127.0.0.1:3004
# PULSE_URL=http://127.0.0.1:3006

# ponytail: RetainDB + Infisical deferred — see docs/scope.md
# Vault resolves secret://env/gateway-api-key from GATEWAY_API_KEY above
# VAULT_ENCRYPTION_KEY=  # 32-byte hex or passphrase for POST /v1/vault/secrets (AES-256-GCM)
